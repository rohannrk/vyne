generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  workspaces    WorkspaceUser[]
  accounts      Account[]
  sessions      Session[]
}

model Workspace {
  id         String             @id @default(cuid())
  name       String
  createdAt  DateTime           @default(now())
  connection GitHubConnection?
  components ComponentConfig[]
  presets    ComponentPreset[]
  users      WorkspaceUser[]
}

model WorkspaceUser {
  id            String    @id @default(cuid())
  workspaceId   String
  userId        String
  role          Role      @default(VIEWER)
  lastVisitedAt DateTime?
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  user          User      @relation(fields: [userId], references: [id])
}

model GitHubConnection {
  id                     String    @id @default(cuid())
  workspaceId            String    @unique
  repoOwner              String
  repoName               String
  branch                 String
  componentDirectoryPath String
  connectedAt            DateTime  @default(now())
  lastPulledAt           DateTime?
  workspace              Workspace @relation(fields: [workspaceId], references: [id])
}

model ComponentConfig {
  id             String            @id @default(cuid())
  workspaceId    String
  componentName  String
  props          Json
  githubFilePath String?
  status         ComponentStatus   @default(PENDING_ADD)
  lastSyncedAt   DateTime?
  lastPushedAt   DateTime?
  presets        ComponentPreset[]
  workspace      Workspace         @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, componentName])
}

model ComponentPreset {
  id                String          @id @default(cuid())
  workspaceId       String
  componentConfigId String
  name              String
  values            Json
  createdAt         DateTime        @default(now())
  workspace         Workspace       @relation(fields: [workspaceId], references: [id])
  componentConfig   ComponentConfig @relation(fields: [componentConfigId], references: [id])
}

// Auth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum ComponentStatus {
  PENDING_ADD
  SYNCED
  MODIFIED
  PENDING_PUSH
}
